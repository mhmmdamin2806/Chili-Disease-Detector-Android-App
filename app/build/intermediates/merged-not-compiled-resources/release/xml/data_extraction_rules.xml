<?xml version="1.0" encoding="utf-8"?>
<!--
   Aturan ekstraksi data untuk Android 12+.
   Aplikasi ini tidak menyimpan data sensitif, sehingga backup dinonaktifkan.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
    </device-transfer>
</data-extraction-rules>
